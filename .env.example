# Supabase — from your project's API settings
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key for admin/Edge actions (NEVER expose to the client).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — transactional email (Arabic notifications & invitations)
RESEND_API_KEY=your-resend-api-key
# From address shown to recipients. Must be a verified Resend domain.
RESEND_FROM="Everest Ads <noreply@everestads.com>"

# Secret protecting cron endpoints (e.g. daily standup reminder). Vercel Cron
# sends it as a Bearer token. Generate any random string.
CRON_SECRET=your-cron-secret

# Google Drive OAuth (Phase 5)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback

# Encryption key for OAuth tokens at rest (Phase 5). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DRIVE_TOKEN_ENCRYPTION_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (optional). Generate a key pair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# The public key is exposed to the browser; the private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI sent with each push (mailto: or https:).
VAPID_SUBJECT=mailto:admin@everestads.com

# WhatsApp Cloud API (optional). When set, notifications are also delivered
# via WhatsApp to each user's number (profile whatsapp/phone field), gated by
# their notification preferences. Create an app + phone number at
# https://developers.facebook.com/apps (WhatsApp > API Setup).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Subdomain tenancy (optional). Set the root domain (no scheme) and add a
# wildcard DNS record + wildcard domain in Vercel (*.deepentry.net) so each
# organization is reachable at <slug>.deepentry.net.
NEXT_PUBLIC_ROOT_DOMAIN=
