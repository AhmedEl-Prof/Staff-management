# Supabase — from your project's API settings
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key for admin/Edge actions (NEVER expose to the client).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — transactional email (Arabic notifications & invitations)
RESEND_API_KEY=your-resend-api-key
# From address shown to recipients. Must be a verified Resend domain.
RESEND_FROM="Everest Ads <noreply@everestads.com>"

# Google Drive OAuth (Phase 5)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback

# Encryption key for OAuth tokens at rest (Phase 5). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DRIVE_TOKEN_ENCRYPTION_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
